+// `accumulate` in an ungrouped query → not implemented (no GROUP BY → the
+// double-aggregate window is undefined).
+#[tokio::test(flavor = "multi_thread")]
+async fn test_accumulate_ungrouped_rejected() {
+    let ctx = create_context();
